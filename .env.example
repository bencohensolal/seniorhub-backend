PORT=4000
HOST=0.0.0.0
PERSISTENCE_DRIVER=in-memory
DATABASE_URL=postgres://postgres:postgres@localhost:5432/seniorhub
TOKEN_SIGNING_SECRET=replace-with-at-least-16-characters
INVITATION_WEB_FALLBACK_URL=https://seniorhub.app/invite
EMAIL_JOB_MAX_RETRIES=3
EMAIL_JOB_RETRY_DELAY_MS=1000

# Email Provider Configuration
# Options: 'console' (logs to console), 'gmail' (Gmail SMTP), or 'resend' (Resend API)
EMAIL_PROVIDER=console

# Gmail SMTP Configuration (required when EMAIL_PROVIDER=gmail)
# Get an App Password from https://myaccount.google.com/apppasswords
# GMAIL_USER=your-email@gmail.com
# GMAIL_APP_PASSWORD=your-16-char-app-password
# EMAIL_FROM=Senior Hub <your-email@gmail.com>

# Resend Configuration (required when EMAIL_PROVIDER=resend)
# Get your API key from https://resend.com/api-keys
# RESEND_API_KEY=re_123456789
# EMAIL_FROM=Senior Hub <noreply@seniorhub.app>

# Optional: leave empty to disable web fallback
# INVITATION_WEB_FALLBACK_URL=

# ─── RevenueCat ────────────────────────────────────────────────────────────────
# Webhook auth key — set in RevenueCat dashboard > Integrations > Webhooks
# REVENUECAT_WEBHOOK_AUTH_KEY=your-webhook-auth-key

# ─── Plan Limits ──────────────────────────────────────────────────────────────
# Use -1 for unlimited. All values have sensible defaults (shown below).

# Gratuit (free tier)
# PLAN_GRATUIT_MAX_SENIORS=1
# PLAN_GRATUIT_MAX_CAREGIVERS=2
# PLAN_GRATUIT_MAX_MEDICATIONS_PER_SENIOR=3
# PLAN_GRATUIT_MAX_ACTIVE_APPOINTMENTS=3
# PLAN_GRATUIT_MAX_ACTIVE_TASKS=5
# PLAN_GRATUIT_MAX_CAREGIVER_TODOS=5
# PLAN_GRATUIT_STORAGE_QUOTA_MB=100
# PLAN_GRATUIT_MAX_TABLETS=0
# PLAN_GRATUIT_MAX_PHOTO_SCREENS_PER_TABLET=0
# PLAN_GRATUIT_MAX_EMERGENCY_CONTACTS=2
# PLAN_GRATUIT_HISTORY_DAYS=7

# Famille
# PLAN_FAMILLE_MAX_SENIORS=2
# PLAN_FAMILLE_MAX_CAREGIVERS=4
# PLAN_FAMILLE_MAX_MEDICATIONS_PER_SENIOR=15
# PLAN_FAMILLE_MAX_ACTIVE_APPOINTMENTS=15
# PLAN_FAMILLE_MAX_ACTIVE_TASKS=-1
# PLAN_FAMILLE_MAX_CAREGIVER_TODOS=-1
# PLAN_FAMILLE_STORAGE_QUOTA_MB=2048
# PLAN_FAMILLE_MAX_TABLETS=2
# PLAN_FAMILLE_MAX_PHOTO_SCREENS_PER_TABLET=3
# PLAN_FAMILLE_MAX_EMERGENCY_CONTACTS=8
# PLAN_FAMILLE_HISTORY_DAYS=90

# Sérénité
# PLAN_SERENITE_MAX_SENIORS=-1
# PLAN_SERENITE_MAX_CAREGIVERS=-1
# PLAN_SERENITE_MAX_MEDICATIONS_PER_SENIOR=-1
# PLAN_SERENITE_MAX_ACTIVE_APPOINTMENTS=-1
# PLAN_SERENITE_MAX_ACTIVE_TASKS=-1
# PLAN_SERENITE_MAX_CAREGIVER_TODOS=-1
# PLAN_SERENITE_STORAGE_QUOTA_MB=20480
# PLAN_SERENITE_MAX_TABLETS=5
# PLAN_SERENITE_MAX_PHOTO_SCREENS_PER_TABLET=5
# PLAN_SERENITE_MAX_EMERGENCY_CONTACTS=-1
# PLAN_SERENITE_HISTORY_DAYS=-1
